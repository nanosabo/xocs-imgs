n"])</script><script>self.__next_f.push([1,"4:[\"$\",\"$Le\",null,{\"formats\":\"$undefined\",\"locale\":\"ru\",\"messages\":{\"Navbar\":{\"menu\":\"Меню\",\"main\":\"Главная\",\"view_all\":\"Смотреть всё\"},\"Footer\":{\"info\":\"Crossoutcore.ru - это фан-ресурс, который не имеет отношения к компаниям Targem Games, Gaijin Entertainment и Pixel Storm.\",\"privacyPolicy\":\"Политика конфиденциальности\"},\"ThemeSwitcher\":{\"title\":\"Тема\"},\"SortableTable\":{\"total\":\"Всего: {count}\",\"configureColumns\":\"⚙️ Настроить колонки\",\"noData\":\"Нет данных для отображения\"},\"MenuItems\":{\"building\":\"Конструкционки и автосборка\",\"building_description\":\"Характеристики всех деталей в игре, с учётом их сопротивлений к разным типам урона. Сравнение деталей между собой, поиск самых эффективных и автоматическое добавление в сборку.\",\"market\":\"Рынок и производство\",\"market_description\":\"Обновляемые каждые 5 минут цены на рынке Crossout, автоматический подсчёт спреда, стоимости производства и прибыли от продажи. Поможет получать постоянный доход от производства самых выгодных товаров.\",\"resist-calculator\":\"Устойчивость\",\"resist-calculator_description\":\"Расчет устойчивости с учётом Оберега, Беркута и тому подобного. Калькулятор, чтобы понять важную механику в Crossout и перестать думать, что у оберега на самом деле 23% устойчивости вместо обещанных 30%\",\"cabin-stacks\":\"Стаки кабин\",\"cabin-stacks_description\":\"Наглядная демонстрация того, как работают стаки Долорес, Каталины и Маяка в игре. Множитель урона на каждом уровне и расчет того, сколько нанесет оружие на каждом из уровней.\",\"badge-exchange\":\"Обмен значков\",\"badge-exchange_description\":\"Расчёт самого выгодного обмена Значков Механиков на ресурсы и контейнеры.\",\"crafting-calculator\":\"Универсальный станок\",\"crafting-calculator_description\":\"Калькулятор для подсчета профита на станках из любых батлпассов, акций и ивентов. Достаточно лишь добавить нужные предметы и ресурсы в рецепт, после чего станок покажет, насколько выгодно крафтить сейчас.\",\"flash-crashes\":\"Обвалы цен\",\"flash-crashes_description\":\"Отслеживание резких падений рыночных цен, когда кто-то выставляет предмет буквально по цене покупки и есть несколько минут, чтобы забрать его со скидкой. Инструмент для спекулянтов.\",\"bp-calculator\":\"Калькулятор БП\",\"bp-calculator_description\":\"Расчёт прогресса Боевого Пропуска, с учётом текущего опыта, пропущенных дней и так далее. Позволяет понять, сколько зажигалок или подшипников можно получить в конце, а также точно рассчитать, какое количество предметов и какой редкости можно забрать со станка.\",\"invasion\":\"Вторжение\",\"invasion_description\":\"Посчитает, насколько выгодно фармить Вторжение с Левиафанами, учитывая винрейт, цену на бензин и медь. И подскажет, сколько времени жизни будет потрачено на это увлекательное занятие.\",\"tierlist\":\"Тир-лист\",\"tierlist_description\":\"Составь свой тир-лист лучший деталей в игре. Кабины, оружие, ходовые, модули и конструкционки.\",\"penetration\":\"Пробивная способность\",\"penetration_description\":\"Калькулятор, который покажет, как работает механика пробития в Crossout, что даёт пробивная способность оружия и почему порядок установки деталей на крафт важен. Есть два режима: для обычного оружия с пробивной способностью и для Скорпиона.\",\"promo\":\"Промокоды и наборы\",\"promo_description\":\"Промокоды, бесплатные наборы, наклейки и реферальные ссылки.\",\"market-analysis\":\"Анализ цен\",\"market-analysis_description\":\"Анализ стоимости ресурсов относительно исторических цен. Подскажет, насколько выгодно торговать рудой, пластиком, металлоломом и прочими ресурсами сейчас.\",\"pump-signals\":\"Рост цен\",\"pump-signals_description\":\"Анализирует рост цены и количества лотов на покупку вместе со снижением числа лотов на продажу.\",\"recycling\":\"Разбор декора\",\"recycling_description\":\"Таблица рентабельности переработки декора и красок. Узнай, что выгоднее: продать на рынке или разобрать на ресурсы.\",\"dlc-packs\":\"Выгода наборов\",\"dlc-packs_description\":\"Рейтинг окупаемости донатных наборов. Автоматический расчет стоимости содержимого по рынку, сравнение выгоды при продаже ресурсов или использовании в крафте.\",\"guides\":\"Гайды и база знаний\",\"guides_description\":\"Заработок монет, решение ошибок, FPS, рынок и полезные советы по Crossout\",\"guides_gold\":\"Заработок и экономика\",\"guides_technical\":\"Технические вопросы\",\"guides_mechanics\":\"Игровые механики\",\"about\":\"О проекте\",\"about_description\":\"Обратная связь и немного информации про сайт.\"},\"HomePage\":{\"title\":\"Crossout Core\",\"description\":\"Сделай свой билд лучше, подобрав идеальные конструкционные детали. Узнай механики игры, разобравшись в сопротивлении и устойчивости к урону. Производи предметы, выгодно продавая их на рынке.\",\"all_guides\":\"Все гайды\",\"donate_title\":\"Донат\",\"donate_desc\":\"На домен, хостинг или просто поблагодарить за контент и отсутствие рекламы. СБП, T‑Pay и банковские карты.\"},\"RootClientWrapper\":{\"alert\":\"\"},\"NotFound\":{\"title\":\"Страница не найдена\",\"button\":\"Вернуться на главную\"},\"privacyPolicy\":{\"meta\":{\"title\":\"Политика конфиденциальности\",\"description\":\"Политика конфиденциальности\"},\"title\":\"Политика конфиденциальности\"},\"marketItemsPageView\":{\"meta\":{\"title\":\"Рынок Crossout: цены онлайн и выгодный крафт\",\"description\":\"Актуальные цены рынка Crossout в реальном времени. Таблица с расчетом прибыли от крафта предметов, графики цен, поиск выгодных лотов и перекуп\"},\"title\":\"Рынок Crossout и производство\",\"buttons\":{\"showFilter\":\"Показать фильтр\",\"hideFilter\":\"Скрыть фильтр\"},\"columns\":{\"name\":\"Название\",\"sellPrice\":\"Цена продажи\",\"buyPrice\":\"Цена покупки\",\"offers\":\"Предложений\",\"orders\":\"Запросов\",\"spread\":\"Спред\",\"roi\":\"ROI (%)\",\"craftCost\":\"Производство\",\"profit\":\"Прибыль\",\"craftTotal\":\"Производство (итого)\",\"profitTotal\":\"Прибыль (итого)\"},\"tooltips\":{\"addToFavorites\":\"Добавить в избранное\",\"removeFromFavorites\":\"Убрать из избранного\",\"excludeFromCraft\":\"Исключить из доступных для производства\",\"restoreToCraft\":\"Вернуть в доступные для производства\",\"spread\":\"Разница между лучшей ценой продажи и покупки, с учётом комиссии рынка\",\"roi\":\"Потенциальная доходность (%) от арбитража спреда за одну сделку, с учётом комиссии рынка\",\"craftCost\":\"Себестоимость производства на станке\",\"profit\":\"Разница между себестоимостью производства и ценой продажи. Комиссия учтена\",\"craftTotal\":\"Учитывает, что такие предметы, как колёса, крафтятся сразу по 2 штуки. Себестоимость производства на станке\",\"profitTotal\":\"Учитывает, что такие предметы, как колёса, крафтятся сразу по 2 штуки. Разница между себестоимостью производства и ценой продажи. Комиссия учтена\"},\"requiresWorkpiece\":\"Требует заготовку\",\"requiresWorkpieceTooltip\":\"Для крафта этого предмета требуется заготовка, полученная в событиях (например, Батлпассы)\",\"unknown\":\"Неизвестно\",\"removed\":\"Удаленный\",\"updated\":\"Обновлено\",\"updatesIn\":\"Обновление через\",\"marketData\":\"Рыночные данные\",\"sell\":\"Продажа\",\"buy\":\"Покупка\",\"currentPrice\":\"Текущая цена\",\"bestOffer\":\"Лучшее предложение\",\"offers\":\"Предложений\",\"requests\":\"Запросов\",\"spread\":\"Спред\",\"afterCommission\":\"После комиссии 10%\",\"roiDesc\":\"Возврат инвестиций\",\"noMarketData\":\"Нет рыночных данных\",\"priceTracking\":\"Отслеживание цены\",\"priceType\":\"Тип цены\",\"sellPrice\":\"Цена продажи\",\"buyPrice\":\"Цена покупки\",\"condition\":\"Условие\",\"below\":\"Ниже указанной\",\"above\":\"Выше указанной\",\"maxPrice\":\"Максимальная цена\",\"minPrice\":\"Минимальная цена\",\"trackingActive\":\"Предмет отслеживается. Теперь на любой странице сайта цена доступна через иконку справа внизу экрана. Если цена достигнет заданного порога, появится уведомление.\",\"cancelTracking\":\"Отменить\",\"addTracking\":\"Добавить отслеживание\",\"craftingRecipe\":\"Рецепт крафта\"},\"ItemsFilters\":{\"search_placeholder\":\"Поиск по названию\",\"production\":{\"title\":\"Производство\",\"mode_title\":\"Режим\",\"modes\":{\"auto\":\"⚙️Авто\",\"craft\":\"🛠️Крафт\",\"buy\":\"💰Покупка\"},\"tooltips\":{\"auto\":\"Авто - минимальная цена производства и максимальная прибыль. Для каждого ингредиента в рецепте сайт самостоятельно решает, выгоднее купить или скрафтить.\",\"optimizer_label\":\"Уникализатор\",\"optimizer_desc\":\"Оставляет по одному самому прибыльному предмету для каждого станка каждой фракции, чтобы занять все слоты производства. Учитывает, что колёса крафтятся по 2 штуки.\"}},\"toggles\":{\"favorites\":\"Только избранные\",\"craftable\":\"Только крафтящиеся\",\"workpiece\":\"Учитывать заготовки\",\"workpiece_tooltip\":\"Включите, чтобы учитывать предметы, требующие заготовку для производства. Заготовки выдавались во временных событиях, таких, как Батлпассы.\"},\"groups\":{\"category\":\"Категория\",\"rarity\":\"Редкость\",\"faction\":\"Фракция\"},\"ranges\":{\"sell_price\":\"Цена продажи\",\"buy_price\":\"Цена покупки\",\"sell_orders\":\"Лоты на продажу\",\"buy_orders\":\"Лоты на покупку\",\"spread\":\"Спред\"},\"reset_btn\":\"Сбросить все фильтры\"},\"AnomalyDetection\":{\"meta\":{\"title\":\"Мгновенные обвалы цен на рынке Crossout\",\"description\":\"Поиск быстрого падения цены за короткий период, чтобы купить на дне и продать после восстановления\"},\"h1\":\"Мгновенные обвалы цен на рынке\",\"showFilter\":\"Показать фильтр\",\"analysisPeriod\":\"Период анализа (минут):\",\"minProfitCoins\":\"Мин. выгода (монет):\",\"minRequests\":\"Мин. запросов:\",\"minBuyers\":\"Мин. покупателей:\",\"minBuyersTooltip\":\"Минимальное соотношение покупателей к продавцам, показывает востребованность товара.\",\"columns\":{\"name\":\"Название\",\"priceHistory\":\"История цен\",\"sellPriceWithWindow\":\"Продажа ({time} мин)\",\"sellPriceWindowTooltip\":\"Цена продажи за последние {time} мин.\",\"sellPrice\":\"Продажа\",\"sellPriceTooltip\":\"Цена продажи сейчас\",\"buyPrice\":\"Покупка\",\"buyPriceTooltip\":\"Цена покупки сейчас\",\"offers\":\"Предложений\",\"requests\":\"Запросов\",\"buyerRatio\":\"B/S\",\"buyerRatioTooltip\":\"Соотношение покупателей к продавцам\",\"profit\":\"Прибыль\",\"profitTooltip\":\"Потенциальная прибыль, которую вы получите, если купите по текущей продаже и продадите по средней цене продажи\",\"roi\":\"ROI (%)\",\"roiTooltip\":\"Потенциальная доходность (%) от арбитража за одну сделку, с учётом комиссии рынка\"}},\"LinksRow\":{\"updateIn\":\"Обновление через: {seconds}\",\"market\":\"Рынок\",\"flashCrashes\":\"Обвалы цен\",\"badgeExchange\":\"Обмен значков\",\"marketAnalysis\":\"Анализ цен\",\"pumpSignals\":\"Рост цен\",\"recycling\":\"Разбор декора\",\"crafting-calculator\":\"Универсальный станок\"},\"BadgeExchange\":{\"meta\":{\"title\":\"Самый выгодный обмен значков механиков в Crossout\",\"description\":\"Калькулятор выгодного обмена значков на ресурсы в Crossout\"},\"pageTitle\":\"Обмен значков на ресурсы\",\"configureExchanges\":\"Настройка доступных обменов на станке\",\"resetAll\":\"Сбросить все\",\"badgesLabel\":\"Количество значков:\",\"badgesPlaceholder\":\"Введите количество значков\",\"calculationModeLabel\":\"Режим расчета:\",\"buyPriceMode\":\"По цене покупки\",\"sellPriceMode\":\"По цене продажи\",\"calculateButton\":\"Рассчитать\",\"totalIncome\":\"Общий доход\",\"coins\":\"{value} монет\",\"unusedBadges\":\"Неиспользованные значки\",\"leftovers\":\"Остатки ресурсов\",\"noLeftovers\":\"Нет остатков\",\"usedExchanges\":\"Использованные обмены:\",\"sellRecommendations\":\"Рекомендации по продаже:\",\"noSellRecommendations\":\"Нет рекомендаций по продаже\",\"profitableExchangesTitle\":\"Выгодные обмены:\",\"profitableExchangesDesc\":\"Лучший выбор сейчас, чтобы обменять значки и продать на рынке. Указан профит за один значок с учётом комиссии. Учитываются ресурсы и комплекты снаряжения.\",\"rotationTimeTooltip\":\"Время до смены ротации\",\"allResourcesTitle\":\"Все ресурсы и комплекты снаряжения\",\"calculatorTitle\":\"Калькулятор обмена значков механиков\",\"howToUse\":\"Как использовать:\",\"profitSellDesc\":\"Выгода (продажа) – доход за 1 значок при продаже ресурсов по рыночной цене\",\"profitBuyDesc\":\"Выгода (покупка) – доход за 1 значок при быстрой продаже по цене покупки\",\"howToList\":{\"profitSellTitle\":\"Выгода (продажа)\",\"profitSellDesc\":\"доход за 1 значок при продаже ресурсов по рыночной цене\",\"profitBuyTitle\":\"Выгода (покупка)\",\"profitBuyDesc\":\"доход за 1 значок при быстрой продаже по цене покупки\",\"tableNoteTitle\":\"В таблице\",\"tableNoteDesc\":\"показаны все предложения, на станке в игре часть из них неактивна\",\"feeNoteTitle\":\"Учитывается комиссия\",\"feeNoteDesc\":\"10% (минимум 0.01 монеты)\",\"calculatorNoteTitle\":\"Калькулятор\",\"calculatorNoteDesc\":\"пытается найти самое выгодное для обмена и последующей продажи комбо.\"},\"table\":{\"resource\":\"Ресурс\",\"units\":\"Единиц\",\"badgesRequired\":\"Требует значков\",\"sellPrice\":\"Цена продажи\",\"buyPrice\":\"Цена покупки\",\"profitSell\":\"Выгода (продажа)\",\"profitBuy\":\"Выгода (покупка)\",\"exchange\":\"Обмен\",\"count\":\"Количество\",\"badges\":\"Значков\",\"resources\":\"Ресурсов\",\"lot\":\"Лот\",\"lotsCount\":\"Количество лотов\"},\"badgeShort\":\"зн.\",\"unitShort\":\"шт.\",\"days\":\"д\",\"hours\":\"ч\",\"exchangeFormat\":\"{amount} за {badges} значков\",\"exchangeLabel\":\"Обмен\",\"resourceNames\":{\"685\":\"Комплект снаряжения У1\",\"686\":\"Комплект снаряжения У2\",\"687\":\"Комплект снаряжения У3\",\"688\":\"Комплект снаряжения У4\",\"700\":\"Комплект снаряжения С1\",\"701\":\"Комплект снаряжения С2\",\"702\":\"Комплект снаряжения С3\",\"1425\":\"Аккумуляторы\",\"1430\":\"Пластик\",\"1432\":\"Медь\",\"1434\":\"Металлолом\",\"1437\":\"Электроника\",\"1438\":\"Провода\"},\"uKitGroupName\":\"Комплект снаряжения У\",\"sKitGroupName\":\"Комплект снаряжения С\"},\"BattlePass\":{\"meta\":{\"title\":\"Калькулятор боевого пропуска в Crossout\",\"description\":\"Узнай уровень, количество зажигалок и наград в очередном БП\"},\"title\":\"Калькулятор Battle Pass\",\"progress\":{\"title\":\"Прогресс\",\"level\":\"Уровень\",\"exp\":\"Опыт\",\"timeLeft\":\"Осталось времени\",\"timeLeftValue\":\"{days} дн. {hours} ч.\",\"weeksLeft\":\"Недель осталось\",\"endedWarning\":\"Батлпасс завершился. Отображаются результаты последнего дня.\"},\"resources\":{\"currentTitle\":\"Ресурсы сейчас\",\"futureTitle\":\"В конце БП\",\"coins\":\"Монеты\",\"badges\":\"Значки\",\"lighters\":\"Зажигалки\",\"bearings\":\"Подшипники\"},\"settings\":{\"title\":\"Настройки Battle Pass\",\"battlePassLabel\":\"Battle Pass\",\"typeLabel\":\"Тип Battle Pass\",\"typePremium\":\"БП куплен\",\"typeElite\":\"Элитный БП\",\"boughtLevels\":\"Куплено уровней\"},\"adjustment\":{\"title\":\"Корректировка прогресса\",\"currentLevel\":\"Текущий уровень\",\"currentLevelTooltip\":\"Уровень БП в игре\",\"currentDay\":\"День БП\",\"currentDayTooltip\":\"По умолчанию показывает текущий. Можно менять, чтобы посмотреть награды через неделю и так далее\",\"missedDays\":\"Пропущенные дни\",\"exp\":\"Опыт\",\"reset\":\"Сбросить\"},\"exchange\":{\"title\":\"Обмен зажигалок/подшипников\",\"remainLabel\":\"Остаток\",\"remainTooltip\":\"Сколько {resource} есть сейчас и не потрачено на станках\",\"nowLabel\":\"Можно обменять сейчас: {amount}\",\"nowTooltip\":\"Какие предметы со станка можно взять за текущее количество {resource}\",\"endLabel\":\"Можно обменять в конце БП: {amount}\",\"endTooltip\":\"Какие предметы со станка можно взять в конце БП при условии, что не будет пропущено ни одного задания\",\"description1\":\"Ползунком «Остаток» укажите, сколько у вас сейчас есть {resource}. Его максимальное значение ограничено текущим днём и уровнем БП. Если хотите рассчитать, сколько будет через неделю или месяц, сначала воспользуйтесь корректировкой прогресса.\",\"description2\":\"Калькулятор старается распределить ваше количество подшипников или зажигалок так, чтобы получить со станка больше предметов высокой редкости. То есть, в приоритете {legendary} редкость, далее {epic} и в самом конце {special}.\",\"description3\":\"Например, у вас есть 1325 зажигалок - калькулятор предложит забрать со станка 2 {legendary}. Но можно вручную указать, что нужен 1 {epic}, после чего калькулятор пересчитает, что со станка можно забрать 1 {legendary}, 2 {epic} и 1 {special} на сдачу.\",\"costLegendary\":\"650 зажигалок/подшипников\",\"costEpic\":\"250 зажигалок/подшипников\",\"costSpecial\":\"140 зажигалок/подшипников\",\"short\":{\"legendary\":\"Лега\",\"epic\":\"Эпик\",\"special\":\"Особ\"}},\"rarity\":{\"legendary\":\"Легендарная\",\"epic\":\"Эпическая\",\"special\":\"Особая\",\"legendaryGenitive\":\"легендарки\",\"epicGenitive\":\"эпика\",\"specialGenitive\":\"бирюзу\"},\"rewards\":{\"importantTitle\":\"Полученные награды (Эпические/Легендарные)\",\"allTitle\":\"Все награды ({level})\",\"level\":\"Уровень\"},\"date\":{\"bpDay\":\"День БП\",\"weekday\":\"День недели\",\"date\":\"Дата\"},\"weekdays\":{\"sunday\":\"воскресенье\",\"monday\":\"понедельник\",\"tuesday\":\"вторник\",\"wednesday\":\"среда\",\"thursday\":\"четверг\",\"friday\":\"пятница\",\"saturday\":\"суббота\"},\"tabs\":{\"selectCalculator\":\"Выбор калькулятора\",\"exchange\":\"Обмен зажигалок/подшипников\",\"craftingCost\":\"Цена ресурсов для крафта\"}},\"CraftingCalculator\":{\"meta\":{\"title\":\"Универсальный станок: стоимость и выгода производства в Crossout\",\"description\":\"Рассчитайте стоимость крафта любых предметов в Crossout. Узнайте прибыль с учетом комиссии рынка 10%.\"},\"title\":\"Универсальный станок Crossout\",\"description\":\"Считает стоимость и выгоду производства предметов на акционных, ивентовых и любых других станках: от новогоднего до батлпасса.\",\"events\":{\"filter\":\"Выбор станков\",\"allActive\":\"Все доступные\",\"myWorkbenches\":\"Мои станки\",\"active\":\"доступны\",\"inactive\":\"недоступны\"},\"currency\":\"монет\",\"import\":{\"maxLimitReached\":\"Достигнут лимит проектов ({max}).\",\"fileTooLarge\":\"Ошибка: Файл слишком большой (макс. 2MB).\",\"invalidFormat\":\"Ошибка: Неверный формат файла (ожидается массив проектов).\",\"noValidProjects\":\"Файл не содержит валидных проектов.\",\"corruptedFile\":\"Ошибка при чтении файла. Возможно, поврежден JSON.\",\"title\":\"Импорт проектов из JSON\",\"label\":\"Импорт\"},\"exportAll\":{\"title\":\"Экспорт всех станков (скачать JSON)\",\"label\":\"Экспорт\"},\"create\":{\"label\":\"Создать\"},\"delete\":{\"confirm\":\"Вы уверены, что хотите удалить этот проект?\"},\"empty\":{\"title\":\"Нет проектов\",\"description\":\"Создайте свой первый расчет крафта или импортируйте готовые.\",\"createButton\":\"Создать проект\"},\"comparison\":{\"title\":\"Сравнение доходности\",\"empty\":\"Добавьте проекты и выберите предметы для сравнения\",\"errorTooltip\":\"Ошибка в компонентах\",\"priceError\":\"Ошибка цены\",\"column\":{\"workbench\":\"Станок\",\"craftingCost\":\"Стоимость крафта\",\"sellPrice\":\"Цена продажи\",\"profit\":\"Прибыль\",\"roi\":\"ROI%\",\"actions\":\"Действия\"},\"tooltip\":{\"craftingCost\":\"Общая стоимость всех компонентов\",\"sellPrice\":\"Цена продажи крафтового предмета\",\"profit\":\"Чистая прибыль после комиссии\",\"roi\":\"Процент возврата инвестиций\"}},\"settings\":{\"acquisitionMethod\":\"Метод получения:\",\"method\":{\"auto\":{\"label\":\"Авто\",\"tooltip\":\"Авто - минимальная цена производства\"},\"craft\":{\"label\":\"Крафт\",\"tooltip\":\"Всегда производить, если возможно\"},\"buy\":{\"label\":\"Покупка\",\"tooltip\":\"Всегда покупать компоненты\"}},\"showWorkpiece\":{\"label\":\"Учитывать заготовки\",\"tooltip\":\"Включите, чтобы учитывать предметы, требующие заготовку для производства. Заготовки выдавались во временных событиях, таких, как Батлпассы.\"},\"componentPrice\":{\"label\":\"Покупка компонентов\",\"tooltip\":\"По какой цене покупать ресурсы и предметы для крафта на станке\",\"buy\":\"Цена покупки\",\"sell\":\"Цена продажи\"},\"craftedPrice\":{\"label\":\"Продажа скрафченного\",\"tooltip\":\"По какой цене продавать скрафченные на станке предметы\",\"buy\":\"Цена покупки\",\"sell\":\"Цена продажи\"}},\"selector\":{\"defaultCustomName\":\"Мой предмет\",\"buyShort\":\"Покупка:\",\"sellShort\":\"Продажа:\",\"buyPriceLabel\":\"Цена покупки:\",\"sellPriceLabel\":\"Цена продажи:\",\"noData\":\"Нет данных\",\"noItemSelected\":\"Предмет не выбран\",\"searchMode\":\"Поиск на рынке\",\"customMode\":\"Своё имя\",\"searchLabel\":\"Поиск предмета Crossout\",\"searchPlaceholder\":\"Начните вводить название...\",\"customLabel\":\"Название создаваемого предмета\",\"customPlaceholder\":\"Например: Слон (тюн.)\",\"customPriceNotTracked\":\"Цена продажи не отслеживается\",\"selectItemPrompt\":\"Выберите предмет из базы для начала расчета\",\"enterNamePrompt\":\"Введите название предмета для начала расчета\",\"priceZeroWarning\":\"Внимание: Цена предмета равна 0. Расчет прибыли будет некорректным.\"},\"custom\":{\"title\":\"Кастомные станки\"},\"editor\":{\"backButton\":\"Назад\",\"creatingNew\":\"Создание нового станка...\",\"craftedItemSection\":\"Предмет крафта\",\"componentsSection\":\"Компоненты\",\"hideForm\":\"Скрыть форму\",\"addManual\":\"+ Добавить вручную\",\"addCraftedItem\":\"Созданный на станке\",\"addCustomItem\":\"Свой предмет\",\"customNameLabel\":\"Название\",\"customNamePlaceholder\":\"Например: Аренда станка\",\"customPriceLabel\":\"Цена\",\"addButton\":\"Добавить\",\"selectCraftedProject\":\"Выбери ранее созданный станок\",\"selectPlaceholder\":\"-- Станки --\",\"unnamed\":\"Безымянный станок\",\"error\":\"Ошибка!\",\"addLinkButton\":\"Добавить ссылку\",\"emptyRecipe\":\"Рецепт пуст. Добавьте компоненты.\",\"resultsTitle\":\"Результаты\",\"craftingCost\":\"Себестоимость\",\"sellPrice\":\"Цена продажи\",\"commission\":\"Комиссия ({percent}%)\",\"profit\":\"Прибыль\",\"notTradeable\":\"Предмет не продаётся\",\"calculationError\":\"Ошибка расчета\",\"errorDescription\":\"Невозможно рассчитать стоимость. Один или несколько компонентов имеют нулевую цену.\",\"errorDetails\":\"Раскройте компоненты с ошибкой, чтобы узнать подробности.\",\"noCalculation\":\"Расчет невозможен\",\"createButton\":\"Создать кастомный станок\",\"closeButton\":\"Закрыть\"},\"grid\":{\"exportTitle\":\"Экспорт\",\"editTitle\":\"Изменить\",\"deleteTitle\":\"Удалить\",\"lockedTitle\":\"Предустановленный станок, экспорт и редактирование недоступны\",\"noComponents\":\"Нет компонентов\",\"cost\":\"Себестоимость\",\"market\":\"Рынок\",\"profit\":\"Прибыль\",\"calculationError\":\"Ошибка в расчетах\",\"noPriceData\":\"Нет данных о ценах\"},\"recipe\":{\"buyLinked\":\"Купить (линк)\",\"craftLinked\":\"Крафтить (линк)\",\"buyLinkedAuto\":\"Купить (линк, авто)\",\"craftLinkedAuto\":\"Крафтить (линк, авто)\",\"methodCraft\":\"Крафтить\",\"methodBuy\":\"Купить\",\"linkedAuto\":\"Линковано (авто)\",\"linked\":\"Линковано\",\"quantity\":\"Кол-во\",\"error\":\"Ошибка\",\"cost\":\"Стоимость\",\"remove\":\"Удалить\",\"priceStructure\":\"Структура цены:\"}},\"DlcPacks\":{\"meta\":{\"title\":\"Калькулятор наборов Crossout %YEAR% - выгода покупки и стоимость монет\",\"description\":\"Актуальная таблица окупаемости донатных наборов Crossout в %YEAR% году. Узнайте, какой набор выгоднее купить ради продажи ресурсов.\"},\"pageTitle\":\"Калькулятор выгоды наборов\",\"coins\":\"Монеты\",\"priceModeLabel\":\"Режим цен\",\"commissionLabel\":\"Стратегия\",\"modeSell\":\"Продать\",\"modeUse\":\"Оставить\",\"modeTooltip\":\"Режим «Продать» учитывает 10% налог рынка. Выбирайте «Оставить», если планируете использовать детали для сборки или улучшения - так вы сохраняете их полную стоимость.\",\"buyPrice\":\"Цена покупки\",\"sellPrice\":\"Цена продажи\",\"viewModeLabel\":\"Отображение\",\"grid\":\"Плитка\",\"table\":\"Таблица\",\"dlcCardsTitle\":\"Наборы DLC\",\"tableTitle\":\"Сравнение наборов\",\"dlcName\":\"Название\",\"price\":\"Цена\",\"items\":\"Предметов\",\"totalValue\":\"Стоимость предметов\",\"efficiency\":\"Монет за {currency}\",\"regionLabel\":\"Регион\",\"totalValueShort\":\"Монет\",\"efficiencyShort\":\"Монет / {currency}\",\"itemsShort\":\"Кол-во\",\"noDlcData\":\"Нет данных для отображения\"},\"Building\":{\"metadata\":{\"title\":\"Детали в Crossout: характеристики и подбор лучших конструкционок для билда\",\"description\":\"Инструмент для подбора, сравнения и анализа конструкционных деталей в игре Crossout. Рейтинг, фильтры, сборки, урон, сопротивление и многое другое.\"},\"title\":\"Характеристики и подбор лучших конструкционок\",\"alert\":{\"info\":\"Используйте кнопку \u003cb\u003eНастроить колонки\u003c/b\u003e, чтобы включить отображение сопротивлений к урону, выделить важную характеристику или убрать ненужные колонки из таблицы.\"},\"sidebar\":{\"mobileButtonLabel\":\"Показать фильтр\"},\"categories\":{\"1\":\"Конструкции\",\"2\":\"Рамы\",\"3\":\"Простреливаемые\",\"4\":\"Контактные\"},\"table\":{\"columns\":{\"part\":\"Деталь\",\"durability\":\"Прочность\",\"build_hp\":\"HP билда\",\"mass\":\"Масса\",\"power\":\"ОМ\",\"size\":\"Размер\",\"effective_durability_per_mass\":\"Прочн./Масса\",\"effective_durability_per_power\":\"Прочн./ОМ\",\"hp_per_mass\":\"HP/Масса\",\"hp_per_power\":\"HP/ОМ\"},\"resist_tooltips\":{\"pass_through\":\"Пропуск урона\",\"bullet_resist\":\"Сопротивление огнестрельному урону\",\"blast_resist\":\"Сопротивление взрывному урону\",\"fire_resist\":\"Сопротивление термическому урону\",\"cryo_resist\":\"Сопротивление криогенному урону\",\"energo_resist\":\"Сопротивление энергетическому урону\",\"contact_resist\":\"Сопротивление контактному урону\",\"ram_resist\":\"Сопротивление таранному урону\",\"ram_bonus\":\"Бонус к таранному урону\"},\"actions\":{\"manual_add\":\"Добавлена вручную\",\"remove_from_compare\":\"Убрать из сравнения\",\"add_to_compare\":\"Добавить к сравнению\",\"remove_from_blacklist\":\"Убрать из чёрного списка\",\"add_to_blacklist\":\"Добавить в чёрный список. Исключает деталь из автоматического подбора\",\"remove_from_build\":\"Удалить из сборки\",\"add_to_build\":\"Добавить в сборку\",\"count_in_build\":\"Количество в сборке\"}},\"filters\":{\"search_placeholder\":\"Поиск по названию и пинам\",\"categories\":\"Категории\",\"factions\":\"Фракции\",\"efficiency\":\"Эффективность\",\"resistances\":\"Сопротивления\",\"bonuses\":\"Бонусы\",\"range_labels\":{\"power\":\"Очки мощи\",\"mass\":\"Масса\",\"hp\":\"HP\",\"durability\":\"Прочность детали\",\"pass_through\":\"Пропуск урона\",\"hp_per_mass\":\"HP/Масса\",\"hp_per_power\":\"HP/ОМ\",\"eff_durability_per_mass\":\"Прочн./Масса\",\"eff_durability_per_power\":\"Прочн./ОМ\",\"ram_bonus\":\"К таранному урону\"},\"tooltips\":{\"hp\":\"Повышает прочность машины\",\"durability\":\"Прочность самой детали\",\"pass_through\":\"Процент урона, который проходит сквозь деталь\",\"hp_per_mass\":\"Соотношение количества HP, которое даёт деталь билду, и массы детали\",\"hp_per_power\":\"Соотношение количества HP, которое даёт деталь билду, и очков мощи детали\",\"eff_durability_per_mass\":\"Соотношение прочности детали и её массы\",\"eff_durability_per_power\":\"Соотношение прочности детали и её очков мощи\"},\"resist_short\":{\"pass_through\":\"Пропуск урона\",\"bullet_resist\":\"Пулевой\",\"blast_resist\":\"Взрывной\",\"contact_resist\":\"Контактный\",\"cryo_resist\":\"Криогенный\",\"fire_resist\":\"Термический\",\"energo_resist\":\"Энергетический\",\"ram_resist\":\"Таранный\"},\"reset_button\":\"Сбросить все фильтры\"},\"buildStats\":{\"title\":\"Статистика сборки\",\"table\":{\"parts\":\"Детали\",\"other\":\"Остальное\",\"whole\":\"Весь билд\",\"durability\":\"Прочность\",\"powerScore\":\"Очки мощи\",\"mass\":\"Масса\",\"partsCount\":\"Деталей\"},\"cards\":{\"pinsAndSizes\":{\"title\":\"Пины и размеры деталей\",\"description\":\"Чтобы на сайте появились поиск и подбор по пинам конструкционок, нужно заполнить их, поскольку такой информации в готовом виде нигде нет. Если есть свободное время и желание, добро пожаловать в Google Sheets. \u003cb\u003eПро ошибки сообщать сюда же.\u003c/b\u003e\",\"button\":\"Перейти\"},\"shareBuilds\":{\"title\":\"Сохранение сборок и отправка друзьям\",\"description\":\"Теперь можно скопировать ссылку, чтобы сохранить любое количество сборок для себя или поделиться с кем-то. Просто нажми кнопку «Ссылка на сборку» и все детали, вместе с лимитами и характеристиками билда, будут доступны при переходе по полученной ссылке.\"}},\"inputs\":{\"currentMass\":\"Текущая масса\",\"tonnage\":\"Грузоподъемность\",\"currentPower\":\"Текущий ОМ\",\"powerLimit\":\"Лимит ОМ\",\"usedParts\":\"Использовано деталей\",\"cabHp\":\"Прочность кабины\",\"minHpLimit\":\"Мин. HP детали\"},\"tooltips\":{\"currentMass\":\"Масса рамы, кабины, бамперов, модулей, оружия, ходовой\",\"tonnage\":\"Лимит, после которого начнётся перегруз билда. В игре нужно навести курсор на полоску грузоподъемности\",\"currentPower\":\"ОМ рамы, кабины, бамперов, модулей, оружия, ходовой\",\"powerLimit\":\"Максимальный ОМ для билда. Если ограничений нет, нужно поставить 0\",\"usedParts\":\"Сколько уже потрачено деталей на раму, кабину, бамперы, модули, оружие, ходовую\",\"cabHp\":\"Сколько прочности имеет кабина, учитывая её апы.\",\"minHpLimit\":\"Детали, дающие прочность ниже заданного значения, не будут участвовать в подборе\",\"cabBonus\":\"Кабина апнута на прочность\",\"grizzly\":\"Выбран напарник Гризли\"},\"checkboxes\":{\"cabBonus\":\"Прочность кабины +10%\",\"grizzly\":\"Гризли +5%\"},\"optimization\":{\"title\":\"Режим подбора деталей\",\"tooltip\":\"\u003cb\u003eСтандартный:\u003c/b\u003e Оптимальный баланс прочности и затрат.\\n\u003cb\u003eМаксимум прочности:\u003c/b\u003e Только максимальное HP, игнорируя эффективность.\\n\u003cb\u003eЗащита от ...:\u003c/b\u003e Подбор деталей с лучшим эффективным HP против конкретного урона.\",\"options\":{\"standard\":\"Стандартный (Баланс)\",\"max_hp\":\"Максимум прочности\",\"bullet\":\"Защита от пуль\",\"blast\":\"Защита от взрыва\",\"fire\":\"Защита от огня\",\"energy\":\"Защита от энергии\"}},\"buttons\":{\"autoBuild\":\"Подобрать детали\",\"autoBuildError\":\"Подбор невозможен\",\"removeAuto\":\"Удалить авто детали\",\"removeManual\":\"Удалить ручные детали\",\"copyLink\":\"Ссылка на сборку\",\"copied\":\"Скопировано\"},\"placeholders\":{\"unlimited\":\"0 = безлимит\"}},\"requiredSizes\":{\"title\":\"Обязательные размеры деталей\",\"addForm\":{\"title\":\"Добавить размер\",\"countPlaceholder\":\"Кол-во\",\"addButton\":\"Добавить\"},\"help\":{\"title\":\"Как использовать\",\"description\":\"Позволяет указать, сколько деталей определённого размера нужно обязательно добавить в автоматический подбор. Порядок цифр в размере не имеет значения, 1х2х4 = 2х4х1. Задав размеры, можно менять количество таких деталей и калькулятор будет стараться включить их в сборку. Если деталей недостаточно, либо размеры указаны неправильно, то подбор не сработает.\",\"note\":\"Больше заданных размеров, вручную добавленных деталей и деталей в чс - меньше эффективность автоподбора.\"},\"existingSizes\":\"Заданные размеры\",\"removeTitle\":\"Удалить\"},\"buildSection\":{\"tabs\":{\"build\":\"Сборка\",\"manual\":\"Добавленные вручную\",\"blacklist\":\"Чёрный список\"}},\"units\":{\"units\":\"ед.\",\"kg\":\"кг\"},\"detailModal\":{\"size\":\"Размер\",\"durability\":\"Прочность детали\",\"buildHp\":\"Повышает прочность на\",\"powerScore\":\"Очки мощи\",\"mass\":\"Масса\",\"maxInInventory\":\"Максимум на складе\",\"ratingsTitle\":\"Рейтинги\",\"ratings\":{\"hpPerMass\":{\"label\":\"HP / Масса\",\"tooltip\":\"Соотношение прочности, которую деталь добавляет билду, и массы\"},\"hpPerPower\":{\"label\":\"HP / ОМ\",\"tooltip\":\"Соотношение прочности, которую деталь добавляет билду, и очков мощности\"},\"durabilityPerMass\":{\"label\":\"Деталь / Масса\",\"tooltip\":\"Соотношение прочности самой детали и массы\"},\"durabilityPerPower\":{\"label\":\"Деталь / ОМ\",\"tooltip\":\"Соотношение прочности самой детали и очков мощности\"}},\"features\":\"Особенности и применение\"},\"analyze\":{\"prosTitle\":\"Плюсы:\",\"consTitle\":\"Минусы:\",\"notesTitle\":\"Особенности:\",\"messages\":{\"frameNote\":\"Эта деталь - рама и служит основой билда.\",\"ramResistPro\":\"Есть сопротивление к таранному или контактному урону.\",\"ramBonusPro\":\"Имеет бонус к урону при таране: наносит на {percent}% больше урона врагам.\",\"noBuildHpCon\":\"Не добавляет прочности билду.\",\"passThroughPro\":\"Пропускает часть урона сквозь себя - это увеличивает фактическую прочность детали.\",\"passThroughCon\":\"Оставшийся урон проходит дальше - может повредить вторую деталь или прикрытый модуль.\",\"noBulletCon\":\"Нет сопротивления к огнестрельному урону.\",\"bulletResistPro\":\"Есть сопротивление к огнестрельному урону.\",\"noBlastCon\":\"Нет сопротивления к взрывному урону.\",\"blastResistPro\":\"Есть сопротивление к взрывному урону.\",\"applicationRamWeapon\":\"Подходит для установки в роли оружия благодаря {percent}% бонусного урона от тарана.\",\"applicationRamBumper\":\"Подходит для установки в роли бампера, можно прикрыть раму и защититься от милишных противников.\",\"applicationGrate\":\"Подобные решётки используют, чтобы установить на них оружие или закрепить другие детали.\",\"applicationPassThrough\":\"Простреливаемая деталь, которая добавляет HP. В зависимости от билда, может размещаться как снаружи на уязвимых местах в качестве брони, так и внутри, чтобы надёжно соединять другие детали и увеличивать прочность крафта.\",\"applicationInteresting\":\"Интересная конструкционка, увеличивающая прочность на {buildHp} при том, что у неё самой {durability}. Повышенное сопротивление работает только на белой части.\",\"applicationClassic\":\"Классическая конструкционка. Есть сопротивление к огнестрельному и взрывному урону, увеличивает прочность крафта.\",\"applicationDurable\":\"Прочная конструкционка. Есть сопротивление к огнестрельному урону и много HP. Такие часто ставят в качестве внешней брони спереди и по бокам.\",\"applicationDefault\":\"Конструкционка, у которой нет самых важных сопротивлений к урону, зато увеличивает прочность крафта. Лучше устанавливать в те места, куда реже стреляют враги.\"}},\"groups\":{\"core\":\"Основные параметры\",\"resists\":\"Сопротивление\",\"effective\":\"Эффективная прочность\",\"damage\":\"Распределение урона\"},\"params\":{\"core\":{\"size\":\"Размер\",\"durability\":\"Прочность\",\"build_hp\":\"HP билда\",\"power\":\"Очки мощи\",\"mass\":\"Масса\",\"hp_per_mass\":\"HP / Масса\",\"hp_per_power\":\"HP / ОМ\",\"effective_durability_per_mass\":\"Прочн./масса\",\"effective_durability_per_power\":\"Прочн./ОМ\",\"tooltips\":{\"size\":\"Длина×Ширина×Высота в пинах\",\"durability\":\"Прочность самой детали\",\"build_hp\":\"Прочность, которую деталь добавляет всей конструкции\",\"power\":\"Сколько ОМ требует установка детали\",\"mass\":\"Масса детали в килограммах\",\"hp_per_mass\":\"Соотношение добавляемой прочности билда к массе\",\"hp_per_power\":\"Соотношение добавляемой прочности к ОМ\",\"effective_durability_per_mass\":\"Соотношение собственной прочности детали к массе\",\"effective_durability_per_power\":\"Соотношение собственной прочности детали к очкам мощности\"}},\"resists\":{\"items\":{\"pass_through\":\"Пропускает\",\"bullet_resist\":\"Пулевой\",\"blast_resist\":\"Взрывной\",\"contact_resist\":\"Контактный\",\"cryo_resist\":\"Криогенный\",\"fire_resist\":\"Термический\",\"energo_resist\":\"Энергетический\",\"ram_resist\":\"Таранный\"},\"tooltips\":{\"pass_through\":\"Деталь пропускает сквозь себя указанный процент огнестрельного, взрывного, термического и криогенного урона\",\"bullet_resist\":\"Снижает урон от пуль\",\"blast_resist\":\"Снижает урон от взрывов\",\"contact_resist\":\"Снижает урон от контакта\",\"cryo_resist\":\"Снижает урон от холода\",\"fire_resist\":\"Снижает урон от огня\",\"energo_resist\":\"Снижает энергетический урон\",\"ram_resist\":\"Снижает урон от ударов\"}},\"effective\":{\"items\":{\"base\":\"Базовая\",\"bullet\":\"Против пуль\",\"blast\":\"Против взрывов\",\"contact\":\"Против контактного оружия\",\"cryo\":\"Против крио\",\"fire\":\"Против термо\",\"energy\":\"Против энерго\",\"ram\":\"Против тарана\"},\"tooltips\":{\"base\":\"Основная прочность детали с учётом простреливаемости\",\"bullet\":\"Прочность против оружия, наносящего огнестрельный урон\",\"blast\":\"Прочность против оружия, наносящего взрывной урон\",\"contact\":\"Прочность против оружия, наносящего контактный урон\",\"cryo\":\"Прочность против оружия, наносящего криогенный урон\",\"fire\":\"Прочность против оружия, наносящего термический урон\",\"energy\":\"Прочность против оружия, наносящего энергетический урон\",\"ram\":\"Прочность против оружия, наносящего таранный урон\"}}},\"damageVisualization\":{\"tabs\":{\"bullet\":\"Огнестрельное оружие\",\"penetration\":\"Скорпион\"},\"inputs\":{\"damage\":\"Урон одного орудия\",\"penetration\":\"Пробивная способность (%)\",\"noxPerk\":\"Бонус Нокс (%)\"},\"tooltips\":{\"damage\":\"Базовый урон оружия по сфере.\",\"penetration\":\"Минимальный урон, который должен остаться в снаряде после прохождения.\",\"noxPerk\":\"Дополнительный бонус к пробивной способности от перка Нокс.\",\"fused\":\"Оружие апнуто на улучшение пробивной способности +20%\"},\"checkbox\":{\"fused\":\"Ап на улучшение пробивной способности\"},\"segments\":{\"absorbed\":\"Поглощено деталью\",\"passed\":\"Прошло дальше\"},\"summary\":{\"behind\":\"Итоговый урон за деталью\",\"absorbed\":\"Поглощено деталью\"},\"damageBarTitle\":\"Распределение огнестрельного урона:\"}},\"CraftingRecipe\":{\"treeNotAvailable\":\"Дерево не доступно\",\"tabBuyLabel\":\"По цене покупки\",\"tabSellLabel\":\"По цене продажи\",\"profitLabel\":\"Прибыль\",\"productionCostLabel\":\"Производство\",\"totalProfitLabel\":\"Прибыль (итого)\",\"totalProductionCostLabel\":\"Производство (итого)\"},\"CraftingDecisionTree\":{\"actionCraft\":\"К